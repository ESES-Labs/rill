{
  "name": "rill",
  "private": true,
  "workspaces": ["rill-backend", "rill-frontend", "packages/*"],
  "scripts": {
    "dev:backend": "bun run --filter rill-backend dev",
    "dev:frontend": "bun run --filter rill-frontend dev",
