PORT=3002
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443

# Public URL for MCP skill links (set to deployed URL in production)
PUBLIC_BASE_URL=https://api.rill.rifuki.dev

# Optional: override simulate sender for devInspect
SIMULATE_SENDER=

# Optional: explicit executor (defaults to Sui CLI active_address + keystore)
# EXECUTOR_ADDRESS=
# EXECUTOR_PRIVATE_KEY=
# SUI_KEYSTORE_PATH=~/.sui/sui_config/sui.keystore

# Walrus audit trail (upload simulate/execute logs after each run)
WALRUS_ENABLED=false
WALRUS_UPLOAD_RELAY=https://upload-relay.testnet.walrus.space
WALRUS_EPOCHS=3
WALRUS_MAX_TIP_MIST=5000000
WALRUS_EXPLORER_BASE=https://walruscan.com/testnet/blob
