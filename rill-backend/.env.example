PORT=3002
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_MAINNET_RPC_URL=https://fullnode.mainnet.sui.io:443

# Public URL for MCP skill links (set to deployed URL in production)
PUBLIC_BASE_URL=https://api.rill.rifuki.dev

# Keyless mode (default): backend builds unsigned PTBs only — Thiny / wallet signs.
# Set DEV_SIGN_ENABLED=true only for local/VPS dev testing (NOT for production demo).
DEV_SIGN_ENABLED=false

# Optional: override simulate sender for devInspect
SIMULATE_SENDER=

# Dev-only server signer (ignored unless DEV_SIGN_ENABLED=true)
# EXECUTOR_ADDRESS=
# EXECUTOR_PRIVATE_KEY=
# SUI_KEYSTORE_PATH=~/.sui/sui_config/sui.keystore

# On-chain agent wallet (when teammate deploys agent_wallet Move package)
# AGENT_WALLET_PACKAGE_ID=
# AGENT_WALLET_OBJECT_ID=
# AGENT_CAP_OBJECT_ID=
# AGENT_WALLET_COIN_TYPE=0x2::sui::SUI

# Walrus audit trail — requires DEV_SIGN + executor key for server-side uploads
WALRUS_ENABLED=false
WALRUS_UPLOAD_RELAY=https://upload-relay.testnet.walrus.space
WALRUS_EPOCHS=3
WALRUS_MAX_TIP_MIST=5000000
WALRUS_EXPLORER_BASE=https://walruscan.com/testnet/blob
